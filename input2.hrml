<html>

<head>
    <meta charset="utf-8" />
    <style>
        table {
            border-collapse: collapse;
            width: 100%;
            margin-bottom: 20px;
        }

        table,
        td,
        th {
            border: 1px solid #ffffff;
        }

        td,
        th {
            padding: 6px 8px;
            vertical-align: top;
        }

        :root {
            --docx-color-1: #000000;
            --docx-color-2: #0000ff;
            --docx-color-3: #d9d9d9;
            --docx-color-4: #ee0000;
            --docx-color-5: #ff0000;
            --docx-color-6: #ffff00;
            --docx-color-7: #ffffff;
        }

        body {
            padding: 96px 120px 96px 120px;
            max-width: 816px;
            font-size: 14.67px;
        }

        p {
            margin-block-start: 0;
            margin-block-end: 0;
        }

        td {
            vertical-align: top;
        }

        img {
            display: inline-block;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
            margin-bottom: 20px;
        }

        td,
        th {
            border: 1px solid black;
            padding: 6px;
            vertical-align: top;
        }

        td:first-child {
            width: 35%;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <p style="margin-bottom: 0px; line-height: 1.15; text-align: center"><span
            style=" font-size: 14.67px; font-family: 'Rupee Foradian'; font-weight: bold; ">MEMORANDUM TO THE CCC-CGM COMMITTEE</span></p>
    <p style="margin-bottom: 13.33px; line-height: 1.15; text-align: center"><span
            style=" font-size: 14.67px; font-family: 'Rupee Foradian'; font-weight: bold; ">{{nbfcName}} – Annual Credit Limit under REF</span></p>
    <p style="margin-bottom: 13.33px; line-height: 1.15; text-align: center"> </p>
